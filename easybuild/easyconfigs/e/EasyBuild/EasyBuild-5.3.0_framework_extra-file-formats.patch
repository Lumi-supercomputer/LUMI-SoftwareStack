Add support for lzip-compressed files and tar files to EasyBuild.
By Kurt Lust, kurt.lust@uantwerpen.be for the LUMI consortium.
To re-create the patch, do this in the unpacked EasyBuild install
directories.
diff -Nau easybuild-framework-5.3.0/easybuild/tools/filetools.py.orig easybuild-framework-5.3.0/easybuild/tools/filetools.py
--- easybuild-framework-5.3.0/easybuild/tools/filetools.py.orig	2026-06-17 12:05:09.000000000 +0300
+++ easybuild-framework-5.3.0/easybuild/tools/filetools.py	2026-06-17 12:05:38.000000000 +0300
@@ -170,6 +170,10 @@
     '.tar.xz': "unset TAPE; unxz %(filepath)s --stdout | tar x",
     '.txz': "unset TAPE; unxz %(filepath)s --stdout | tar x",
     '.xz': "unxz %(filepath)s",
+    # Lzipped tarball:
+    '.tar.lz': "unset TAPE; tar -x --lzip -f %(filepath)s",
+    '.tlz':    "unset TAPE; tar -x --lzip -f %(filepath)s",
+    '.lz':     "lzip -cd %(filepath)s > %(target)s",
     # tarball
     '.tar': "tar xf %(filepath)s",
     # zip file
